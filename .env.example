# Database
# SQLite (development)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/football_tracker?schema=public"

# JWT Secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')|cat"
# REQUIRED: application will not start without these
JWT_ACCESS_SECRET="replace-with-64-byte-random-hex-string"
JWT_REFRESH_SECRET="replace-with-64-byte-random-hex-string"
